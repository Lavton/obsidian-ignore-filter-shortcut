{
	"name": "ignore-filters-boost",
	"version": "1.0.0",
	"description": "Simplifing and speed up 'excluded files' (or 'ignore filters') changes: provides menu item to include/remove folder",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"svelte-check": "svelte-check --tsconfig tsconfig.json"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"esbuild": "^0.25.6",
		"esbuild-svelte": "^0.9.3",
		"obsidian": "latest",
		"svelte": "^5.53.5",
		"svelte-check": "^4.3.0",
		"svelte-preprocess": "^6.0.3",
		"tslib": "2.4.0",
		"typescript": "5.8.3"
	},
	"overrides": {
		"ajv": "^6.14.0",
		"brace-expansion": "^1.1.13",
		"flatted": "^3.4.2",
		"js-yaml": "^4.1.1",
		"minimatch": "^3.1.4",
		"picomatch": "^2.3.2"
	}
